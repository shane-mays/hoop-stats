# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for certain text files
*.js      text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.mjs      text eol=lf

# Binary files (never modify line endings)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.ttf     binary
*.woff    binary
*.woff2   binary
*.eot     binary
*.mp4     binary
*.mp3     binary

# Ignore CRLF conversion for images, fonts, videos, etc.
*.lock    binary
